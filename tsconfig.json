{
  // "extends": "astro/tsconfigs/strict",
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    // "strict": true,
    // "noImplicityAny": true,
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@public/*": ["public/*"],
      "@layouts/*": ["src/layouts/*"]
    }
  }
}
