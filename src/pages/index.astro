import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>🐱 Welcome, Sakakibara's blog!</h1>
      <p>
        🚀 Welcome to Sakakibara's blog.
        Here I mainly post blogs about IT technology and mathematics.
        This blog is created mainly for my own memorandum and study, and the contents may be inadequate. Please understand.
        If you want to know more about me, please refer <a href="about">ABOUT ME.</a>
      </p>
    </main>
  </body>
  <Footer />
</html>
