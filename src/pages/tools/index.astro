---
import BaseHead from '@components/BaseHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from 'src/consts';
import { Image } from 'astro:assets';
import toolsImage from './toolsImage.jpg';
---


<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <style>
      .tools__container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        text-align: center;
        gap: 2em;
      }
      .tools__card {
        display: grid;
        grid-template-rows: 1fr auto;
      }
      .title {
        grid-row: 2;
      }
      .title h3 {
        margin: 0;
      }
    </style>
    <main>
      <div class="tools__container">
        <a href={`/tools/tags`} class="tools__card">
          <Image src={toolsImage} alt="tags" />
          <span class="title">
            <h3>Tags</h3>
          </span>
        </a>
        <a href={`/tools/workflow`} class="tools__card">
          <Image src={toolsImage} alt="workflow" />
          <span class="title">
            <h3>Work Flow</h3>
          </span>
        </a>
        <a href={`/tools/guideline`} class="tools__card">
          <Image src={toolsImage} alt="guideline" />
          <span class="title">
            <h3>Guide Line</h3>
          </span>
        </a>
      </div>
    </main>
    <Footer />
  </body>
</html>
