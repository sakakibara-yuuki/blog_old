---
import { type CollectionEntry, getCollection } from 'astro:content';
import GuideLinePost from '@layouts/GuideLinePost.astro';

type Props = CollectionEntry<'guideline'>;

export async function getStaticPaths() {
  const guidelines: Props[] = await getCollection('guideline');
  return guidelines.map((guideline) => ({
    params: { slug: guideline.id },
    props: guideline,
  }));
}

const guideline = Astro.props;
---

<GuideLinePost {...guideline.data} />
