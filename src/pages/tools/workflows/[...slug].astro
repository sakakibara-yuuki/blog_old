---
import { type CollectionEntry, getCollection } from 'astro:content';
import WorkflowPost from '@layouts/WorkflowPost.astro';

type Props = CollectionEntry<'workflow'>;

export async function getStaticPaths() {
  const workflows: Props[] = await getCollection('workflow');
  return workflows.map((workflow) => ({
    params: { slug: workflow.id },
    props: workflow,
  }));
}

const workflow = Astro.props;
---

<WorkflowPost {...workflow.data} />
