---
import HeaderLink from './HeaderLink.astro';
import ThemeIcon from './ThemeIcon.astro';
import SearchBar from './SearchBar.astro';
import { SITE_TITLE } from '../consts';

import { Icon } from 'astro-icon/components';
---

<style>

  header {
    --header-height: 4em;
    height: var(--header-height);
    padding: 0 1em;
    box-shadow: var(--box-shadow);

    position: relative;

    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1em;

    background: var(--md-sys-color-surface-container-low);
  }

  .blog-title  h2 {
    margin: 0;
    padding: 0;
  }

  .blog-title a {
    text-decoration: none;
  }

  .blog-title__block {
    display: grid;
    grid-template-columns: repeat(4, 0.2em);
    grid-template-rows: repeat(4, 0.2em);
    border: 1px solid var(--md-sys-color-outline);
    padding: 0.1em;
    justify-content: center;
    text-align: center;
    vertical-align: middle;
  }

  .blog-title__block div {
    font-size: 0.2em;
    font-weight: 400;
  }

  #hamburger-button {
    display: none;
  }

  #hamburger-button > * {
    grid-column: 1 / -1;
    grid-row: 1 / -1;
  }

  nav {
    height: 100%;
  }

  ul {
    display: flex;
    list-style: none;
    margin: 0;

    li {
      padding: 0 0.6em 0 0.6em;
    }

    a {
      text-decoration: none;
      color: var(--md-sys-color-primary);
      line-height: var(--header-height);
    }

    li:hover {
      background: var(--md-sys-color-primary-container);
      border-bottom: 5px solid var(--md-sys-color-primary);
    }
  }

  @media (max-width: 720px) {

    #hamburger-button {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      justify-content: center;
      align-items: center;
      background: none;
      border: none;
      color: var(--md-sys-color-on-surface);
      font-size: 2em;
    }

    .icon-menue {
      display: block;
    }
    .icon-close {
      display: none;
    }

    nav {
      position: absolute;
      top: var(--header-height);
      right: -100%;
      height: 100vh;
      width: 40%;

      padding-top: var(--header-height);
      overflow-y: hidden;

      background: var(--md-sys-color-surface-container-low);
      box-shadow: var(--box-shadow);

      transition: 0.5s;
    }

    ul {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0;
    }
    ul li {
      width: 100%;
      text-align: center;
    }
  }
</style>

<header>
  <div class="blog-title">
    <h2>
      <a href="/">
        <div class="blog-title__block">
          <div>S</div>
          <div>A</div>
          <div>K</div>
          <div>A</div>
          <div>K</div>
          <div>I</div>
          <div>B</div>
          <div>A</div>
          <div>R</div>
          <div>A</div>
          <div>S</div>
          <div> </div>
          <div>B</div>
          <div>L</div>
          <div>O</div>
          <div>G</div>
        </div>
      </a>
    </h2>
  </div>

  <SearchBar/>

  <!--hamberger menu-->
  <button id="hamburger-button">
    <Icon class="icon-close" name="line-md:close" />
    <Icon class="icon-menue" name="line-md:close-to-menu-alt-transition" />
  </button>

  <nav>
    <ul class="internal-links">
      <li><HeaderLink href="/">Home</HeaderLink></li>
      <li><HeaderLink href="/blog">Blog</HeaderLink></li>
      <li><HeaderLink href="/tags">Tags</HeaderLink></li>
      <li><HeaderLink href="/about">About</HeaderLink></li>
    </ul>
  </nav>

  <ThemeIcon/>

</header>

<script is:inline>
  const handleSideBar = () => {

    const hambergerButton = document.querySelector('#hamburger-button');
    hambergerButton.classList.toggle('open');

    const isOpend = hambergerButton.classList.contains('open');
    const iconMenue = document.querySelector('.icon-menue');
    const iconClose = document.querySelector('.icon-close');

    if (isOpend) {
      document.querySelector('nav').style.right = '0';
      iconMenue.style.display = 'none';
      iconClose.style.display = 'revert';
    } else {
      document.querySelector('nav').style.right = '-100%';
      iconMenue.style.display = 'revert';
      iconClose.style.display = 'none';
    }
  }

  const iconbutton = document.getElementById("hamburger-button");
  iconbutton.addEventListener('click', handleSideBar);
</script>
